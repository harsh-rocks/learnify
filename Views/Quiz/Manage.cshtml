@model ELearningPlatform.Models.Quiz
@{
    ViewData["Title"] = "Manage Quiz";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Manage Quiz for: @Model.Lesson?.Title</h1>
        <a asp-controller="Instructor" asp-action="ManageLessons" asp-route-courseId="@Model.Lesson?.CourseId" class="text-decoration-none"><i class="fa-solid fa-arrow-left mt-1 me-1"></i>Back to Lessons</a>
    </div>
</div>

<div class="row">
    <!-- Quiz Info Form -->
    <div class="col-md-5 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h5 class="mb-0">Quiz Details</h5></div>
            <div class="card-body">
                <form asp-action="EditQuizInfo" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Title</label>
                        <input type="text" name="title" class="form-control" value="@Model.Title" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i> Update Details</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Add Question Form -->
    <div class="col-md-7 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h5 class="mb-0">Add New Question</h5></div>
            <div class="card-body border-bottom">
                <form asp-action="AddQuestion" method="post">
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <div class="row">
                        <div class="col-md-9 mb-3">
                            <label class="form-label fw-bold">Question Text</label>
                            <input type="text" name="text" class="form-control" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label fw-bold">Points</label>
                            <input type="number" name="points" class="form-control" value="1" min="1" required />
                        </div>
                    </div>

                    <label class="form-label fw-bold">Options (Select the correct one)</label>
                    <div class="mb-2 input-group">
                        <div class="input-group-text"><input type="radio" name="correctOptionIndex" value="0" required checked aria-label="Option 1"></div>
                        <input type="text" name="optionTexts" class="form-control" placeholder="Option 1" required>
                    </div>
                    <div class="mb-2 input-group">
                        <div class="input-group-text"><input type="radio" name="correctOptionIndex" value="1" required aria-label="Option 2"></div>
                        <input type="text" name="optionTexts" class="form-control" placeholder="Option 2" required>
                    </div>
                    <div class="mb-2 input-group">
                        <div class="input-group-text"><input type="radio" name="correctOptionIndex" value="2" required aria-label="Option 3"></div>
                        <input type="text" name="optionTexts" class="form-control" placeholder="Option 3" required>
                    </div>
                    <div class="mb-3 input-group">
                        <div class="input-group-text"><input type="radio" name="correctOptionIndex" value="3" required aria-label="Option 4"></div>
                        <input type="text" name="optionTexts" class="form-control" placeholder="Option 4" required>
                    </div>

                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-plus me-1"></i> Add Question</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Existing Questions -->
<h4 class="mb-3 mt-4">Existing Questions (@Model.Questions.Count)</h4>
@foreach (var question in Model.Questions)
{
    var options = question.Options.ToList();
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <h5 class="card-title">@question.Text <small class="text-muted fs-6">(@question.Points pts)</small></h5>
                <form asp-action="DeleteQuestion" method="post" onsubmit="return confirm('Delete this question?');">
                    <input type="hidden" name="id" value="@question.Id" />
                    <input type="hidden" name="quizId" value="@Model.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                </form>
            </div>
            
            <ul class="list-group mt-3">
                @for(int i = 0; i < options.Count; i++)
                {
                    <li class="list-group-item @(options[i].IsCorrect ? "list-group-item-success fw-bold" : "")">
                        @if(options[i].IsCorrect) { <i class="fa-solid fa-check text-success me-2"></i> }
                        else { <i class="fa-regular fa-circle text-muted me-2"></i> }
                        @options[i].Text
                    </li>
                }
            </ul>
        </div>
    </div>
}
