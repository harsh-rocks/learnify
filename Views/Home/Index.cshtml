@model IEnumerable<ELearningPlatform.Models.Course>

@{
    ViewData["Title"] = "Home Page";
    ViewData["FullWidth"] = true;
}

<!-- Hero Section -->
<section class="hero-section mb-5 fade-in-up">
    <div class="container h-100 position-relative">
        <div class="row h-100 align-items-center position-relative z-1">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="display-5 fw-bolder mb-3 text-dark">Unlock Your Potential</h1>
                    <p class="fs-5 text-muted mb-4">Learn practically anything from expert instructors. Over 10,000 top-tier courses to help you achieve your career goals.</p>
                    
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary-custom btn-lg w-100 shadow-sm mb-2">Get Started for Free</a>
                        <p class="text-center small text-muted mt-2">Join over 5 million learners today.</p>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Courses" class="btn btn-primary-custom btn-lg w-100 shadow-sm mb-2">My Learning Path</a>
                    }
                </div>
            </div>
            
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image-container ms-auto">
                    <!-- We use our AI Generated hero image -->
                    <div class="hero-image rounded" style="background-image: url('/images/hero.png');"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trusted By Section (Social Proof) -->
<section class="bg-light py-5 mb-5 border-top border-bottom fade-in-up delay-100">
    <div class="container text-center">
        <p class="text-muted fw-bold mb-4 fs-5">Trusted by over 14,400 companies and millions of learners around the world</p>
        <div class="d-flex justify-content-center align-items-center flex-wrap gap-5 opacity-50">
            <i class="fa-brands fa-microsoft fs-1"></i>
            <i class="fa-brands fa-google fs-1"></i>
            <i class="fa-brands fa-amazon fs-1"></i>
            <i class="fa-brands fa-apple fs-1"></i>
            <i class="fa-brands fa-meta fs-1"></i>
        </div>
    </div>
</section>

<!-- Featured Courses Section -->
<section class="container mb-5 pb-4 fade-in-up delay-200">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Students are viewing</h2>
            <p class="text-muted mb-0">Discover the courses everyone is taking right now.</p>
        </div>
        <a asp-controller="Home" asp-action="Courses" class="btn btn-outline-custom">Browse All</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var course in Model)
            {
                <div class="col">
                    <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="text-decoration-none course-card-wrapper d-block h-100">
                        <div class="card course-card h-100 shadow-sm">
                            <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "/images/course-placeholder.jpg" : course.ImageUrl)" class="card-img-top" alt="@course.Title">
                            <div class="card-body d-flex flex-column">
                                <h3 class="course-title">@course.Title</h3>
                                <p class="course-instructor">@course.Instructor?.FirstName @course.Instructor?.LastName</p>
                                
                                <div class="course-rating mt-auto">
                                    <span class="me-1">4.8</span>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star-half-stroke"></i>
                                    <span class="text-muted small ms-1 fw-normal">(12,453)</span>
                                </div>
                                <div class="course-price fw-bolder mt-2">$@course.Price</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info border-0 shadow-sm">
            <i class="fa-solid fa-info-circle me-2"></i> No courses are currently available. Check back later!
        </div>
    }
</section>

<!-- Value Props Section -->
<section class="container mt-5 pt-4 fade-in-up delay-300">
    <div class="row">
        <div class="col-md-4 text-center mb-4">
            <div class="card h-100 border-0">
                <div class="card-body px-4">
                    <div class="mb-3">
                        <i class="fa-solid fa-chalkboard-user fs-1 text-primary"></i>
                    </div>
                    <h3 class="h5 fw-bold">Learn from Industry Experts</h3>
                    <p class="text-muted small">Select from top instructors around the world who are passionate about sharing their knowledge.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center mb-4">
            <div class="card h-100 border-0">
                <div class="card-body px-4">
                    <div class="mb-3">
                        <i class="fa-solid fa-clock-rotate-left fs-1 text-primary"></i>
                    </div>
                    <h3 class="h5 fw-bold">Go at Your Own Pace</h3>
                    <p class="text-muted small">Enjoy lifetime access to courses on Learnify's website and app.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center mb-4">
            <div class="card h-100 border-0">
                <div class="card-body px-4">
                    <div class="mb-3">
                        <i class="fa-solid fa-certificate fs-1 text-primary"></i>
                    </div>
                    <h3 class="h5 fw-bold">Earn Certificates</h3>
                    <p class="text-muted small">Prove your new skills to employers by earning a certificate of completion.</p>
                </div>
            </div>
        </div>
    </div>
</section>
