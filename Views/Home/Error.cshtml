@model ELearningPlatform.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="display-1 fw-bold text-primary mb-4">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h1 class="fw-bold mb-3">Something went wrong.</h1>
            <p class="text-muted mb-5 fs-5">An error occurred while processing your request. Please try refreshing the page or navigating back to the home page.</p>
            
            <div class="d-flex gap-3 justify-content-center">
                <a href="/" class="btn btn-primary px-4 py-2 fw-bold">
                    <i class="fa-solid fa-house me-2"></i>Go Home
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2 fw-bold">
                    <i class="fa-solid fa-arrow-left me-2"></i>Go Back
                </a>
            </div>

            @if (Model != null && Model.ShowRequestId)
            {
                <div class="mt-5 p-3 bg-light rounded text-start">
                    <p class="small text-muted mb-0"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
                </div>
            }
        </div>
    </div>
</div>
