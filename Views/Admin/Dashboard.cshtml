@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1">Admin Dashboard</h1>
            <p class="text-muted mb-0">Platform overview and management</p>
        </div>
        <span class="badge bg-primary-soft text-primary fw-semibold fs-6 px-3 py-2">
            <i class="fa-solid fa-shield-halved me-1"></i> Admin
        </span>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(164,53,240,0.12); color: var(--primary);">
                <i class="fa-solid fa-users"></i>
            </div>
            <div>
                <div class="stat-card-num">@ViewBag.TotalUsers</div>
                <div class="stat-card-lbl">Total Users</div>
            </div>
            <a asp-action="Users" class="stat-card-link stretched-link">View <i class="fa-solid fa-arrow-right ms-1 fa-sm"></i></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <div>
                <div class="stat-card-num">@ViewBag.TotalCourses</div>
                <div class="stat-card-lbl">Total Courses</div>
            </div>
            <a asp-action="Courses" class="stat-card-link stretched-link">Manage <i class="fa-solid fa-arrow-right ms-1 fa-sm"></i></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(245,158,11,0.12); color: #f59e0b;">
                <i class="fa-solid fa-tags"></i>
            </div>
            <div>
                <div class="stat-card-num">@ViewBag.TotalCategories</div>
                <div class="stat-card-lbl">Categories</div>
            </div>
            <a asp-action="Categories" class="stat-card-link stretched-link">Manage <i class="fa-solid fa-arrow-right ms-1 fa-sm"></i></a>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
                <i class="fa-solid fa-user-graduate"></i>
            </div>
            <div>
                <div class="stat-card-num">@ViewBag.TotalEnrollments</div>
                <div class="stat-card-lbl">Enrollments</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-folder-tree me-2 text-primary"></i>Manage Categories</h5>
                <p class="text-muted small mb-3">Create, edit, or delete course categories to keep the platform organized.</p>
                <a asp-action="Categories" class="btn btn-sm btn-primary">View Categories</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-chalkboard me-2 text-success"></i>Manage Courses</h5>
                <p class="text-muted small mb-3">Oversee all courses on the platform, view enrollments, and remove content.</p>
                <a asp-action="Courses" class="btn btn-sm btn-success">View Courses</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-users me-2 text-info"></i>Manage Users</h5>
                <p class="text-muted small mb-3">View and manage all registered students, instructors, and admins.</p>
                <a asp-action="Users" class="btn btn-sm btn-info text-white">View Users</a>
            </div>
        </div>
    </div>
</div>
