@model IEnumerable<ELearningPlatform.Models.Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1">All Courses</h1>
            <p class="text-muted mb-0">@Model.Count() courses on the platform</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: #f7f9fa;">
                    <tr>
                        <th class="ps-4 py-3 fw-semibold text-muted small text-uppercase">Course</th>
                        <th class="py-3 fw-semibold text-muted small text-uppercase">Category</th>
                        <th class="py-3 fw-semibold text-muted small text-uppercase">Instructor</th>
                        <th class="py-3 fw-semibold text-muted small text-uppercase">Price</th>
                        <th class="py-3 text-end pe-4 fw-semibold text-muted small text-uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(course.ImageUrl))
                                    {
                                        <img src="@course.ImageUrl" alt="" class="rounded" style="width:44px;height:44px;object-fit:cover;flex-shrink:0;">
                                    }
                                    else
                                    {
                                        <div class="rounded d-flex align-items-center justify-content-center"
                                             style="width:44px;height:44px;background:#e9d5ff;flex-shrink:0;">
                                            <i class="fa-solid fa-book text-primary"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-semibold" style="max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@course.Title</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge" style="background:rgba(164,53,240,0.1);color:var(--primary);">@course.Category?.Name</span>
                            </td>
                            <td class="py-3 text-muted">@course.Instructor?.FirstName @course.Instructor?.LastName</td>
                            <td class="py-3 fw-bold text-success">$@course.Price</td>
                            <td class="py-3 text-end pe-4">
                                <form asp-action="DeleteCourse" asp-route-id="@course.Id" class="d-inline"
                                      onsubmit="return confirm('Delete this course and all its content?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-book fa-2x d-block mb-2"></i>
                                No courses created yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
