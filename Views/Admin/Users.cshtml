@model IEnumerable<ELearningPlatform.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1">Registered Users</h1>
            <p class="text-muted mb-0">@Model.Count() total users on the platform</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: #f7f9fa;">
                    <tr>
                        <th class="ps-4 py-3 fw-semibold text-muted small text-uppercase">User</th>
                        <th class="py-3 fw-semibold text-muted small text-uppercase">Email</th>
                        <th class="py-3 fw-semibold text-muted small text-uppercase">Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                         style="width:38px;height:38px;background:var(--primary);font-size:0.9rem;flex-shrink:0;">
                                        @((user.FirstName?.Length > 0 ? user.FirstName[0].ToString() : user.Email?[0].ToString() ?? "?").ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@user.FirstName @user.LastName</div>
                                        <div class="text-muted small">@user.UserName</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">@user.Email</td>
                            <td class="py-3">
                                <span class="badge bg-light text-muted fw-normal">
                                    <i class="fa-regular fa-calendar me-1"></i>
                                    @(user.LockoutEnd.HasValue ? "Locked" : "Active")
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users fa-2x d-block mb-2"></i>
                                No users registered yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
