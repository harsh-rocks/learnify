@using Microsoft.AspNetCore.Identity
@using ELearningPlatform.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var initials = (user?.FirstName?.Length > 0 ? user.FirstName[0].ToString() : user?.Email?[0].ToString() ?? "?").ToUpper();

    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 fw-semibold" href="#"
           id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                 style="width:34px;height:34px;background:var(--primary);font-size:0.85rem;flex-shrink:0;">
                @initials
            </div>
            <span class="d-none d-md-inline">@user?.FirstName</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width:200px; border-radius:10px;">
            <li class="px-3 py-2 border-bottom">
                <div class="fw-semibold small">@user?.FirstName @user?.LastName</div>
                <div class="text-muted" style="font-size:0.75rem;">@user?.Email</div>
            </li>
            @if (User.IsInRole("Student"))
            {
                <li><a class="dropdown-item py-2" asp-controller="Student" asp-action="Dashboard">
                    <i class="fa-solid fa-graduation-cap me-2 text-primary"></i>My Learning
                </a></li>
            }
            @if (User.IsInRole("Instructor"))
            {
                <li><a class="dropdown-item py-2" asp-controller="Instructor" asp-action="Dashboard">
                    <i class="fa-solid fa-chalkboard me-2 text-primary"></i>Instructor Dashboard
                </a></li>
            }
            @if (User.IsInRole("Admin"))
            {
                <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Dashboard">
                    <i class="fa-solid fa-shield-halved me-2 text-primary"></i>Admin Dashboard
                </a></li>
            }
            <li><hr class="dropdown-divider my-1" /></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100 text-start py-2">
                        <i class="fa-solid fa-right-from-bracket me-2"></i>Sign out
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link fw-semibold" asp-controller="Account" asp-action="Login">Log in</a>
    </li>
    <li class="nav-item ms-2">
        <a class="btn-primary-custom" asp-controller="Account" asp-action="Register"
           style="padding: 0.45rem 1.2rem; font-size:0.9rem;">
            Sign up
        </a>
    </li>
}
</ul>
