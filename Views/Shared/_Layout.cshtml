<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Learnify</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Custom Premium CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-graduation-cap me-2"></i>Learnify
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Courses">Courses</a>
                        </li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold" asp-area="" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                            </li>
                        }
                        @if (User.IsInRole("Instructor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold" asp-area="" asp-controller="Instructor" asp-action="Dashboard">Instructor Dashboard</a>
                            </li>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold" asp-area="" asp-controller="Student" asp-action="Dashboard">My Learning</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    
    <!-- Inner pages wrap content in a container by default. Full-width pages self-manage. -->
    <main role="main">
        @if (ViewData["FullWidth"] as bool? == true)
        {
            @RenderBody()
        }
        else
        {
            <div class="container">
                @RenderBody()
            </div>
        }
    </main>

    <footer class="footer-premium">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <h5 class="fw-bold mb-3"><i class="fa-solid fa-graduation-cap me-2 text-white"></i>Learnify</h5>
                    <p class="small text-white-50">Empowering learners globally to achieve their full potential.</p>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="fw-bold text-uppercase mb-3">Platform</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">About Us</a></li>
                        <li class="mb-2"><a href="#">Careers</a></li>
                        <li class="mb-2"><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="fw-bold text-uppercase mb-3">Resources</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Terms of Service</a></li>
                        <li class="mb-2"><a href="#">Privacy Policy</a></li>
                        <li class="mb-2"><a href="#">Help and Support</a></li>
                    </ul>
                </div>
                <div class="col-md-3 pl-md-5">
                    <div class="d-flex gap-3 fs-5">
                       <a href="#"><i class="fa-brands fa-facebook"></i></a>
                       <a href="#"><i class="fa-brands fa-twitter"></i></a>
                       <a href="#"><i class="fa-brands fa-linkedin"></i></a>
                       <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <div class="border-top border-secondary pt-3 mt-3 d-flex justify-content-between align-items-center small">
                <span class="text-white-50">&copy; @DateTime.Now.Year - Learnify, Inc.</span>
            </div>
        </div>
    </footer>
    
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
