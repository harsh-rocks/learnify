@model ELearningPlatform.Models.Quiz
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <!-- Quiz Header -->
        <div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
            <div>
                <p class="text-muted small text-uppercase fw-bold mb-1">
                    <i class="fa-solid fa-clipboard-question me-2 text-primary"></i>Knowledge Check
                </p>
                <h1 class="fw-bold fs-3 mb-1">@Model.Title</h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-0">@Model.Description</p>
                }
            </div>
            <a asp-action="PlayLesson" asp-route-lessonId="@Model.LessonId" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to Lesson
            </a>
        </div>

        @if (!Model.Questions.Any())
        {
            <div class="card border-0 shadow-sm text-center p-5">
                <i class="fa-solid fa-clipboard-question fa-3x text-muted mb-3 d-block"></i>
                <h4 class="fw-bold">Coming Soon</h4>
                <p class="text-muted mb-4">The instructor is still preparing questions for this quiz.</p>
                <div>
                    <a asp-action="PlayLesson" asp-route-lessonId="@Model.LessonId" class="btn-primary-custom">
                        Return to Lesson
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Question count info bar -->
            <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background:#f7f9fa; border: 1px solid #e5e7eb;">
                <i class="fa-solid fa-list-ol text-primary"></i>
                <span class="fw-semibold">@Model.Questions.Count Question@(Model.Questions.Count != 1 ? "s" : "")</span>
                <span class="text-muted">·</span>
                <span class="text-muted small">Select one answer per question</span>
            </div>

            <form asp-action="SubmitQuiz" method="post" id="quiz-form">
                <input type="hidden" name="id" value="@Model.Id" />

                @{ int qIndex = 1; }
                @foreach (var question in Model.Questions)
                {
                    <div class="card border-0 shadow-sm mb-4 question-card" style="border-radius: 12px; overflow: hidden;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 d-flex gap-3">
                                <span class="badge rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                      style="width:32px; height:32px; background: var(--primary); font-size:0.85rem;">@(qIndex++)</span>
                                <span>@question.Text
                                    <small class="fw-normal text-muted ms-2">(@question.Points pts)</small>
                                </span>
                            </h5>

                            <div class="d-grid gap-2">
                                @foreach (var option in question.Options)
                                {
                                    <label class="option-label d-flex align-items-center gap-3 p-3 rounded-3"
                                           for="opt_@option.Id"
                                           style="cursor:pointer; border: 1.5px solid #e5e7eb; transition: all 0.15s ease;">
                                        <input class="form-check-input m-0 flex-shrink-0"
                                               type="radio"
                                               name="question_@question.Id"
                                               id="opt_@option.Id"
                                               value="@option.Id"
                                               required
                                               style="width:1.3em; height:1.3em;" />
                                        <span class="fs-6">@option.Text</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mt-5">
                    <a asp-action="PlayLesson" asp-route-lessonId="@Model.LessonId" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn-primary-custom px-5" style="font-size:1rem; padding:.85rem 2.5rem;">
                        <i class="fa-solid fa-paper-plane me-2"></i>Submit Quiz
                    </button>
                </div>
            </form>
        }
    </div>
</div>

<style>
    .option-label:hover { border-color: var(--primary) !important; background: rgba(164,53,240,0.04); }
    .option-label:has(input:checked) { border-color: var(--primary) !important; background: rgba(164,53,240,0.08); }
</style>
