@model ELearningPlatform.Models.QuizAttempt
@{
    ViewData["Title"] = "Quiz Result";
}

<div class="row justify-content-center my-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 text-center" style="border-radius: 16px; overflow: hidden;">

            <!-- Top accent bar -->
            @{
                string accentColor = Model.Score >= 80 ? "#10b981" : (Model.Score >= 50 ? "#A435F0" : "#ef4444");
            }
            <div style="height: 6px; background: @accentColor;"></div>

            <div class="card-body p-5">
                <!-- Icon & Message -->
                @if (Model.Score >= 80)
                {
                    <div class="mb-3" style="font-size: 4rem;">🏆</div>
                    <h3 class="fw-bold mb-1" style="color: #10b981;">Excellent Work!</h3>
                    <p class="text-muted mb-4">You aced the quiz with flying colors.</p>
                }
                else if (Model.Score >= 50)
                {
                    <div class="mb-3" style="font-size: 4rem;">👍</div>
                    <h3 class="fw-bold mb-1" style="color: var(--primary);">Good Effort!</h3>
                    <p class="text-muted mb-4">You passed! Review the material to strengthen your knowledge.</p>
                }
                else
                {
                    <div class="mb-3" style="font-size: 4rem;">📚</div>
                    <h3 class="fw-bold mb-1" style="color: #ef4444;">Keep Studying</h3>
                    <p class="text-muted mb-4">Review the lesson material and try again — you've got this!</p>
                }

                <!-- Score Circle -->
                <div class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle shadow-sm"
                     style="width: 130px; height: 130px; border: 6px solid @accentColor; background: #fafafa;">
                    <div>
                        <div class="fw-bold" style="font-size: 2.5rem; color: @accentColor; line-height: 1;">@Model.Score<span style="font-size:1.2rem;">%</span></div>
                        <div class="text-muted" style="font-size: 0.7rem;">Score</div>
                    </div>
                </div>

                <!-- Meta info -->
                <div class="d-flex justify-content-center gap-4 mb-5">
                    <div>
                        <div class="fw-bold fs-5">@Model.Quiz?.Title</div>
                        <div class="text-muted small">Quiz</div>
                    </div>
                    <div class="border-start ps-4">
                        <div class="fw-bold fs-5">@Model.AttemptDate.ToLocalTime().ToString("MMM dd")</div>
                        <div class="text-muted small">Attempted</div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a asp-action="TakeQuiz" asp-route-id="@Model.QuizId" class="btn btn-outline-secondary px-4">
                        <i class="fa-solid fa-rotate-right me-2"></i>Try Again
                    </a>
                    <a asp-action="PlayLesson" asp-route-lessonId="@Model.Quiz?.LessonId" class="btn-primary-custom px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>Return to Lesson
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
