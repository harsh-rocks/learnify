@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center my-5">
    <div class="col-md-6 text-center">
        <div class="display-1 fw-bold text-danger mb-4"><i class="fa-solid fa-shield-halved"></i> 403</div>
        <h2 class="fw-bold mb-3">Access Denied</h2>
        <p class="text-muted fs-5 mb-5">You do not have permission to access this page. Please contact your administrator if you think this is a mistake.</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                <i class="fa-solid fa-arrow-left me-2"></i>Go Back
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-primary-custom px-4">
                <i class="fa-solid fa-home me-2"></i>Return Home
            </a>
        </div>
    </div>
</div>
