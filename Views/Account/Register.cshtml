@model ELearningPlatform.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Learnify</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <style>
        body { padding-top: 0; background: #F7F9FA; font-family: 'Inter', sans-serif; }
        .auth-wrapper { min-height: 100vh; display: flex; }
        .auth-brand-panel {
            background: linear-gradient(145deg, #7c22c9 0%, #A435F0 50%, #c084fc 100%);
            color: #fff;
            display: flex; flex-direction: column;
            justify-content: center; align-items: flex-start;
            padding: 3rem 3.5rem; position: relative; overflow: hidden;
        }
        .auth-brand-panel::before {
            content: ''; position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .auth-brand-panel .brand-logo { font-size: 1.8rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 2.5rem; }
        .auth-brand-panel .brand-tagline { font-size: 1.8rem; font-weight: 700; line-height: 1.3; margin-bottom: 1rem; }
        .auth-brand-panel .brand-sub { font-size: 1rem; opacity: 0.85; line-height: 1.6; }
        .auth-brand-panel .perk { display: flex; align-items: center; gap: 0.75rem; margin-top: 1.2rem; font-size: 0.95rem; }
        .auth-brand-panel .perk-icon { background: rgba(255,255,255,0.2); border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .auth-form-panel {
            display: flex; flex-direction: column; justify-content: center;
            align-items: center; padding: 2.5rem 2rem; background: #fff; overflow-y: auto;
        }
        .auth-form-inner { width: 100%; max-width: 480px; }
        .auth-form-inner .form-control, .auth-form-inner .form-select {
            border-radius: 6px; padding: 0.7rem 1rem;
            border-color: #D1D7DC; font-size: 0.95rem;
        }
        .auth-form-inner .form-control:focus, .auth-form-inner .form-select:focus {
            border-color: #A435F0; box-shadow: 0 0 0 3px rgba(164,53,240,0.12);
        }
        /* Firebase status badge */
        #firebase-status {
            display: none;
            align-items: center; gap: 0.5rem;
            font-size: 0.82rem; font-weight: 600;
            padding: 0.4rem 0.9rem; border-radius: 20px;
            margin-bottom: 1rem;
        }
        #firebase-status.verifying { display: flex; background: #ede9fe; color: #7c3aed; }
        #firebase-status.success   { display: flex; background: #d1fae5; color: #065f46; }
        #firebase-status.error     { display: flex; background: #fee2e2; color: #991b1b; }

        .btn-submit-loader { display: none; }
        .btn-loading .btn-submit-text { display: none; }
        .btn-loading .btn-submit-loader { display: inline-block; }

        /* Password strength bar */
        #pw-strength-bar { height: 4px; border-radius: 2px; transition: width 0.3s ease, background 0.3s ease; width: 0; }
    </style>
</head>
<body>
<div class="auth-wrapper">
    <!-- Left Brand Panel -->
    <div class="auth-brand-panel d-none d-md-flex col-md-4">
        <div class="position-relative w-100">
            <a href="/" class="text-white text-decoration-none d-block brand-logo">
                <i class="fa-solid fa-graduation-cap me-2"></i>Learnify
            </a>
            <p class="brand-tagline">Start your learning journey today.</p>
            <p class="brand-sub">Join millions of learners and take control of your future with expert-led courses.</p>

            <div class="mt-3">
                <div class="perk"><div class="perk-icon"><i class="fa-solid fa-graduation-cap fa-sm"></i></div><span>Lifetime access to 10,000+ courses</span></div>
                <div class="perk"><div class="perk-icon"><i class="fa-solid fa-certificate fa-sm"></i></div><span>Earn industry-recognized certificates</span></div>
                <div class="perk"><div class="perk-icon"><i class="fa-solid fa-clock fa-sm"></i></div><span>Learn at your own pace, anytime</span></div>
            </div>

            <!-- Firebase badge -->
            <div class="mt-4 d-flex align-items-center gap-2" style="opacity:0.8; font-size:0.82rem;">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.88 23.4L9.14 4.64l6.62 12.06L5.88 23.4z" fill="#FFA000"/>
                    <path d="M15.76 16.7L9.14 4.64 26.12 23.4 15.76 16.7z" fill="#F57F17"/>
                    <path d="M5.88 23.4l3.26-5.7 2.62 1.48-5.88 4.22z" fill="#FFCA28"/>
                    <path d="M26.12 23.4L15.76 16.7l2.62 10.3-2.14-3.6L26.12 23.4z" fill="#FFA000"/>
                    <path d="M18.38 27l-2.62-10.3 10.36 6.7L18.38 27z" fill="#F57F17"/>
                </svg>
                <span class="text-white">Secured by Firebase Authentication</span>
            </div>
        </div>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-form-panel col-12 col-md-8">
        <div class="auth-form-inner fade-in-up">
            <div class="mb-4">
                <h2 class="fw-bold mb-1">Create your account</h2>
                <p class="text-muted">Already have an account? <a asp-action="Login" class="text-primary fw-semibold">Log in</a></p>
            </div>

            <!-- Firebase status indicator -->
            <div id="firebase-status">
                <i class="fa-solid fa-circle-notch fa-spin" id="fb-icon"></i>
                <span id="fb-status-text">Creating your account...</span>
            </div>

            <form id="register-form" asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                <div id="firebase-error" class="alert alert-danger py-2 small d-none"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label fw-semibold"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="John" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label fw-semibold"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Doe" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" id="reg-email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" placeholder="Min 8 characters" id="reg-password" type="password" />
                            <button class="btn btn-outline-secondary" type="button" id="toggle-pw" tabindex="-1">
                                <i class="fa-regular fa-eye" id="eye-icon"></i>
                            </button>
                        </div>
                        <!-- Password strength indicator -->
                        <div class="mt-1 bg-light rounded" style="height:4px;">
                            <div id="pw-strength-bar"></div>
                        </div>
                        <div id="pw-strength-label" class="text-muted" style="font-size:0.75rem; margin-top:3px;"></div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" id="reg-confirm" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold">I want to join as a...</label>
                    <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <button type="submit" id="register-btn" class="btn btn-primary w-100 py-2 fw-bold" style="background-color: #A435F0; border-color: #A435F0;">
                    <span class="btn-submit-text">Create Account <i class="fa-solid fa-arrow-right ms-2"></i></span>
                    <span class="btn-submit-loader"><i class="fa-solid fa-circle-notch fa-spin me-2"></i>Creating account...</span>
                </button>

                <p class="text-muted small text-center mt-3">By signing up, you agree to our Terms of Service and Privacy Policy.</p>
            </form>
        </div>
    </div>
</div>

<!-- Firebase SDK (modular v10) -->
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-app.js";
    import { getAuth, createUserWithEmailAndPassword, updateProfile } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCCtMbn3Kajbe1XkuiBJuWVQIcFKJ05eIE",
        authDomain: "elearning-platform-51e86.firebaseapp.com",
        projectId: "elearning-platform-51e86",
        storageBucket: "elearning-platform-51e86.firebasestorage.app",
        messagingSenderId: "995964379955",
        appId: "1:995964379955:web:da1fed1e0161cec0761446",
        measurementId: "G-DBCW1K68XR"
    };

    const app  = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const form      = document.getElementById('register-form');
    const statusEl  = document.getElementById('firebase-status');
    const fbIcon    = document.getElementById('fb-icon');
    const fbText    = document.getElementById('fb-status-text');
    const fbError   = document.getElementById('firebase-error');
    const regBtn    = document.getElementById('register-btn');

    // Password visibility toggle
    document.getElementById('toggle-pw').addEventListener('click', () => {
        const pw  = document.getElementById('reg-password');
        const eye = document.getElementById('eye-icon');
        if (pw.type === 'password') { pw.type = 'text'; eye.classList.replace('fa-eye', 'fa-eye-slash'); }
        else                        { pw.type = 'password'; eye.classList.replace('fa-eye-slash', 'fa-eye'); }
    });

    // Password strength indicator
    document.getElementById('reg-password').addEventListener('input', function() {
        const val   = this.value;
        const bar   = document.getElementById('pw-strength-bar');
        const label = document.getElementById('pw-strength-label');
        let strength = 0;
        if (val.length >= 8) strength++;
        if (/[A-Z]/.test(val)) strength++;
        if (/[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const levels = [
            { pct: '0%', color: 'transparent', text: '' },
            { pct: '25%', color: '#ef4444', text: 'Weak' },
            { pct: '50%', color: '#f59e0b', text: 'Fair' },
            { pct: '75%', color: '#3b82f6', text: 'Good' },
            { pct: '100%', color: '#10b981', text: 'Strong' },
        ];
        bar.style.width = levels[strength].pct;
        bar.style.background = levels[strength].color;
        label.textContent = levels[strength].text;
        label.style.color = levels[strength].color;
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email    = document.getElementById('reg-email').value;
        const password = document.getElementById('reg-password').value;
        const confirm  = document.getElementById('reg-confirm').value;
        const firstName = form.querySelector('[name="FirstName"]')?.value || '';
        const lastName  = form.querySelector('[name="LastName"]')?.value  || '';

        // Basic password match check before Firebase call
        if (password !== confirm) {
            fbError.textContent = '❌ Passwords do not match.';
            fbError.classList.remove('d-none');
            return;
        }

        fbError.classList.add('d-none');
        regBtn.classList.add('btn-loading');
        regBtn.disabled = true;

        // Step 1: Firebase — create user
        setStatus('verifying', 'fa-circle-notch fa-spin', 'Creating your Firebase account...');

        try {
            const userCred = await createUserWithEmailAndPassword(auth, email, password);

            // Step 2: Update display name in Firebase
            setStatus('verifying', 'fa-circle-notch fa-spin', 'Setting up your profile...');
            await updateProfile(userCred.user, { displayName: `${firstName} ${lastName}`.trim() });

            setStatus('success', 'fa-circle-check', 'Firebase account created! Finalizing registration...');

            // Step 3: Submit to ASP.NET Identity (which creates the DB user + role assignment)
            setTimeout(() => form.submit(), 600);

        } catch (err) {
            regBtn.classList.remove('btn-loading');
            regBtn.disabled = false;
            statusEl.style.display = 'none';
            fbError.classList.remove('d-none');
            fbError.textContent = getFirebaseError(err.code);
        }
    });

    function setStatus(type, iconClasses, text) {
        statusEl.className = type;
        fbIcon.className = `fa-solid ${iconClasses}`;
        fbText.textContent = text;
        statusEl.style.display = 'flex';
    }

    function getFirebaseError(code) {
        const messages = {
            'auth/email-already-in-use':   '❌ An account with this email already exists. Try logging in.',
            'auth/invalid-email':          '❌ Please list a valid email address.',
            'auth/weak-password':          '❌ Password must be at least 6 characters.',
            'auth/operation-not-allowed':  '⚠️ Email/password sign-up is currently disabled.',
            'auth/network-request-failed': '⚠️ Network error. Check your internet connection.',
        };
        return messages[code] || `❌ Registration failed (${code}). Please try again.`;
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
