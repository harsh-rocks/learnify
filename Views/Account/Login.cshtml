@model ELearningPlatform.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log In - Learnify</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <style>
        body { padding-top: 0; background: #F7F9FA; font-family: 'Inter', sans-serif; }
        .auth-wrapper { min-height: 100vh; display: flex; }
        .auth-brand-panel {
            background: linear-gradient(145deg, #7c22c9 0%, #A435F0 50%, #c084fc 100%);
            color: #fff;
            display: flex; flex-direction: column;
            justify-content: center; align-items: flex-start;
            padding: 3rem 3.5rem; position: relative; overflow: hidden;
        }
        .auth-brand-panel::before {
            content: ''; position: absolute; inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .auth-brand-panel .brand-logo { font-size: 1.8rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 2.5rem; }
        .auth-brand-panel .brand-tagline { font-size: 2rem; font-weight: 700; line-height: 1.3; margin-bottom: 1rem; }
        .auth-brand-panel .brand-sub { font-size: 1rem; opacity: 0.85; line-height: 1.6; }
        .auth-brand-panel .brand-stats { margin-top: 2.5rem; display: flex; gap: 2rem; }
        .auth-brand-panel .brand-stat-num { font-size: 1.5rem; font-weight: 800; }
        .auth-brand-panel .brand-stat-lbl { font-size: 0.78rem; opacity: 0.8; }
        .auth-form-panel {
            display: flex; flex-direction: column; justify-content: center;
            align-items: center; padding: 3rem 2rem; background: #fff;
        }
        .auth-form-inner { width: 100%; max-width: 420px; }
        .auth-form-inner .form-control {
            border-radius: 6px; padding: 0.7rem 1rem;
            border-color: #D1D7DC; font-size: 0.95rem;
        }
        .auth-form-inner .form-control:focus {
            border-color: #A435F0; box-shadow: 0 0 0 3px rgba(164,53,240,0.12);
        }
        /* Firebase status badge */
        #firebase-status {
            display: none;
            align-items: center; gap: 0.5rem;
            font-size: 0.82rem; font-weight: 600;
            padding: 0.4rem 0.9rem; border-radius: 20px;
            margin-bottom: 1rem;
        }
        #firebase-status.verifying { display: flex; background: #ede9fe; color: #7c3aed; }
        #firebase-status.success   { display: flex; background: #d1fae5; color: #065f46; }
        #firebase-status.error     { display: flex; background: #fee2e2; color: #991b1b; }

        .btn-submit-loader { display: none; }
        .btn-loading .btn-submit-text { display: none; }
        .btn-loading .btn-submit-loader { display: inline-block; }
    </style>
</head>
<body>
<div class="auth-wrapper">
    <!-- Left Brand Panel -->
    <div class="auth-brand-panel d-none d-md-flex col-md-5">
        <div class="position-relative w-100">
            <a href="/" class="text-white text-decoration-none d-block brand-logo">
                <i class="fa-solid fa-graduation-cap me-2"></i>Learnify
            </a>
            <p class="brand-tagline">Welcome back, keep learning.</p>
            <p class="brand-sub">Sign in to access your courses, track your progress, and continue your journey toward mastery.</p>
            <div class="brand-stats">
                <div><div class="brand-stat-num">10K+</div><div class="brand-stat-lbl">Courses</div></div>
                <div><div class="brand-stat-num">5M+</div><div class="brand-stat-lbl">Learners</div></div>
                <div><div class="brand-stat-num">500+</div><div class="brand-stat-lbl">Instructors</div></div>
            </div>
            <!-- Firebase badge -->
            <div class="mt-4 d-flex align-items-center gap-2" style="opacity:0.8; font-size:0.82rem;">
                <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5.88 23.4L9.14 4.64l6.62 12.06L5.88 23.4z" fill="#FFA000"/>
                    <path d="M15.76 16.7L9.14 4.64 26.12 23.4 15.76 16.7z" fill="#F57F17"/>
                    <path d="M5.88 23.4l3.26-5.7 2.62 1.48-5.88 4.22z" fill="#FFCA28"/>
                    <path d="M26.12 23.4L15.76 16.7l2.62 10.3-2.14-3.6L26.12 23.4z" fill="#FFA000"/>
                    <path d="M18.38 27l-2.62-10.3 10.36 6.7L18.38 27z" fill="#F57F17"/>
                </svg>
                <span class="text-white">Secured by Firebase Authentication</span>
            </div>
        </div>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-form-panel col-12 col-md-7">
        <div class="auth-form-inner fade-in-up">
            <div class="mb-4">
                <a href="/" class="d-md-none text-decoration-none text-primary fw-bold mb-3 d-block">
                    <i class="fa-solid fa-graduation-cap me-1"></i> Learnify
                </a>
                <h2 class="fw-bold mb-1">Log in to your account</h2>
                <p class="text-muted">Don't have an account? <a asp-action="Register" asp-route-returnurl="@ViewData["ReturnUrl"]" class="text-primary fw-semibold">Sign up</a></p>
            </div>

            <!-- Firebase status indicator -->
            <div id="firebase-status">
                <i class="fa-solid fa-circle-notch fa-spin" id="fb-icon"></i>
                <span id="fb-status-text">Verifying with Firebase...</span>
            </div>

            <form id="login-form" asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <input type="hidden" name="FirebaseApproved" id="firebase-approved" value="false" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" id="server-errors"></div>
                <div id="firebase-error" class="alert alert-danger py-2 small d-none"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" id="login-email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="Password" class="form-control" placeholder="Your password" id="login-password" type="password" />
                        <button class="btn btn-outline-secondary" type="button" id="toggle-pw" tabindex="-1">
                            <i class="fa-regular fa-eye" id="eye-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted"></label>
                </div>

                <button type="submit" id="login-btn" class="btn btn-primary w-100 py-2 fw-bold" style="background-color: #A435F0; border-color: #A435F0;">
                    <span class="btn-submit-text">Log in <i class="fa-solid fa-arrow-right ms-2"></i></span>
                    <span class="btn-submit-loader"><i class="fa-solid fa-circle-notch fa-spin me-2"></i>Signing in...</span>
                </button>

                <!-- Demo helper -->
                <div class="mt-4 p-3 rounded-3" style="background: #fdf2ff; border: 1px dashed #A435F0;">
                    <h6 class="fw-bold mb-2" style="color: #6b21a8;"><i class="fa-solid fa-key me-2"></i>Demo Accounts</h6>
                    <ul class="list-unstyled small mb-0 text-muted">
                        <li class="mb-1"><strong>Admin:</strong> admin@elearning.com / Admin123!</li>
                        <li><strong>Instructor:</strong> instructor@elearning.com / Instructor123!</li>
                    </ul>
                    <p class="x-small mt-2 mb-0 text-muted" style="font-size: 0.75rem;">Copy and paste for immediate access.</p>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Firebase SDK (modular v10) -->
<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-app.js";
    import { getAuth, signInWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-auth.js";

    const firebaseConfig = {
        apiKey: "AIzaSyCCtMbn3Kajbe1XkuiBJuWVQIcFKJ05eIE",
        authDomain: "elearning-platform-51e86.firebaseapp.com",
        projectId: "elearning-platform-51e86",
        storageBucket: "elearning-platform-51e86.firebasestorage.app",
        messagingSenderId: "995964379955",
        appId: "1:995964379955:web:da1fed1e0161cec0761446",
        measurementId: "G-DBCW1K68XR"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const form      = document.getElementById('login-form');
    const statusEl  = document.getElementById('firebase-status');
    const fbIcon    = document.getElementById('fb-icon');
    const fbText    = document.getElementById('fb-status-text');
    const fbError   = document.getElementById('firebase-error');
    const loginBtn  = document.getElementById('login-btn');

    // Password toggle
    document.getElementById('toggle-pw').addEventListener('click', () => {
        const pw  = document.getElementById('login-password');
        const eye = document.getElementById('eye-icon');
        if (pw.type === 'password') { pw.type = 'text'; eye.classList.replace('fa-eye', 'fa-eye-slash'); }
        else                        { pw.type = 'password'; eye.classList.replace('fa-eye-slash', 'fa-eye'); }
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email    = document.getElementById('login-email').value.trim();
        const password = document.getElementById('login-password').value;

        // Show loading state
        loginBtn.classList.add('btn-loading');
        loginBtn.disabled = true;
        fbError.classList.add('d-none');

        // Step 1: Firebase Authentication
        setStatus('verifying', 'fa-circle-notch fa-spin', 'Verifying with Firebase...');

        try {
            await signInWithEmailAndPassword(auth, email, password);
            setStatus('success', 'fa-circle-check', 'Firebase verified! Signing in...');
            document.getElementById('firebase-approved').value = 'true';
            // Step 2: Submit to ASP.NET Identity (which manages the session cookie)
            setTimeout(() => form.submit(), 500);
        } catch (err) {
            // ROBUST HYBRID LOGIC: 
            // If the user isn't found in Firebase, they might be a local seeded account.
            // We proceed to submit to the server anyway to check the local database.
            if (err.code === 'auth/user-not-found' || err.code === 'auth/invalid-credential') {
                setStatus('success', 'fa-circle-check', 'Checking local database... Signing in...');
                setTimeout(() => form.submit(), 500);
            } else {
                loginBtn.classList.remove('btn-loading');
                loginBtn.disabled = false;
                statusEl.style.display = 'none';
                fbError.classList.remove('d-none');
                fbError.textContent = getFirebaseError(err.code);
            }
        }
    });

    function setStatus(type, iconClasses, text) {
        statusEl.className = type;
        fbIcon.className = `fa-solid ${iconClasses}`;
        fbText.textContent = text;
        statusEl.style.display = 'flex';
    }

    function getFirebaseError(code) {
        const messages = {
            'auth/invalid-email':         '❌ Please enter a valid email address.',
            'auth/too-many-requests':     '⚠️ Too many login attempts. Please wait and try again.',
            'auth/user-disabled':         '⚠️ This account has been disabled. Contact support.',
            'auth/network-request-failed':'⚠️ Network error. Check your internet connection.',
        };
        return messages[code] || `❌ Login failed (${code}). Please try again.`;
    }
</script>
</body>
</html>
