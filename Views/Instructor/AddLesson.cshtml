@model ELearningPlatform.Models.ViewModels.LessonCreateViewModel
@{
    ViewData["Title"] = "Add Lesson";
}

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1">Add New Lesson</h1>
            <p class="text-muted mb-0">Create a new lesson and attach a video or document</p>
        </div>
        <a asp-action="ManageLessons" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Lessons
        </a>
    </div>
</div>

<form asp-action="AddLesson" enctype="multipart/form-data" id="lesson-form">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
    <input type="hidden" asp-for="CourseId" />

    <div class="row g-4">
        <!-- Left: Lesson Details -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-muted text-uppercase fw-bold small mb-4">
                        <i class="fa-solid fa-info-circle me-2 text-primary"></i>Lesson Details
                    </h6>

                    <div class="mb-3">
                        <label asp-for="SectionId" class="form-label fw-semibold"></label>
                        <select asp-for="SectionId" class="form-select" asp-items="ViewBag.Sections" required>
                            <option value="">-- Select Section --</option>
                        </select>
                        <span asp-validation-for="SectionId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Introduction to HTML5" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Describe what students will learn in this lesson..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold">Written Lesson Content (Optional)</label>
                        <textarea asp-for="Content" class="form-control" rows="8"
                                  placeholder="Write your text lesson, code examples, or transcripts here..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="OrderIndex" class="form-label fw-semibold">Lesson Order</label>
                            <input asp-for="OrderIndex" type="number" class="form-control" min="1" />
                            <span asp-validation-for="OrderIndex" class="text-danger small"></span>
                            <div class="form-text">Position inside the section</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label fw-semibold">Lesson Duration</label>
                            <div class="input-group">
                                <input asp-for="Duration" type="number" class="form-control" min="0" placeholder="10" />
                                <span class="input-group-text">mins</span>
                            </div>
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-12 mt-4">
                        <div class="form-check form-switch fs-6">
                            <input class="form-check-input" type="checkbox" role="switch" asp-for="IsPreview">
                            <label class="form-check-label fw-semibold ms-2" asp-for="IsPreview">Make this a Free Preview Lesson</label>
                        </div>
                        <div class="form-text mt-1">Free preview lessons can be viewed by anyone without purchasing the course.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Media -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-muted text-uppercase fw-bold small mb-4">
                        <i class="fa-solid fa-photo-film me-2 text-primary"></i>Lesson Media
                    </h6>

                    <!-- YouTube URL field (NEW) -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="fa-brands fa-youtube text-danger me-1"></i>YouTube Video URL
                        </label>
                        <input asp-for="VideoUrl" class="form-control"
                               placeholder="https://www.youtube.com/watch?v=..." />
                        <div class="form-text">Paste a YouTube link — students will watch it embedded in the lesson.</div>
                        <span asp-validation-for="VideoUrl" class="text-danger small"></span>
                    </div>

                    <div class="d-flex align-items-center gap-2 my-3">
                        <hr class="flex-grow-1" />
                        <span class="text-muted small">or upload a file</span>
                        <hr class="flex-grow-1" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="VideoFile" class="form-label fw-semibold">
                            <i class="fa-solid fa-video me-1 text-muted"></i>Upload Video File
                        </label>
                        <input asp-for="VideoFile" type="file" class="form-control" accept="video/*" />
                        <div class="form-text">MP4, MOV up to 100MB. YouTube URL takes priority.</div>
                        <span asp-validation-for="VideoFile" class="text-danger small"></span>
                    </div>

                    <div class="mb-2">
                        <label asp-for="DocumentFile" class="form-label fw-semibold">
                            <i class="fa-solid fa-file-pdf me-1 text-muted"></i>Supplemental Document
                        </label>
                        <input asp-for="DocumentFile" type="file" class="form-control"
                               accept=".pdf,.doc,.docx,.ppt,.pptx" />
                        <div class="form-text">PDF, DOCX, PPT notes or assignments</div>
                        <span asp-validation-for="DocumentFile" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-3 mt-4">
        <a asp-action="ManageLessons" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary px-4">
            Cancel
        </a>
        <button type="submit" class="btn-primary-custom px-5">
            <i class="fa-solid fa-save me-2"></i>Save Lesson
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
