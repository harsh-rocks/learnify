@model IEnumerable<ELearningPlatform.Models.Course>
@{
    ViewData["Title"] = "Instructor Dashboard";
}

<div class="d-flex justify-content-between align-items-center page-header mb-4">
    <div>
        <h1 class="fw-bold mb-1">My Courses</h1>
        <p class="text-muted mb-0">Manage your course catalog and student content</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Students" class="btn btn-outline-secondary">
            <i class="fa-solid fa-users me-2"></i>My Students
        </a>
        <a asp-action="Profile" class="btn btn-outline-secondary">
            <i class="fa-solid fa-user-circle me-2"></i>My Profile
        </a>
        <a asp-action="CreateCourse" class="btn-primary-custom">
            <i class="fa-solid fa-plus me-2"></i>New Course
        </a>
    </div>
</div>

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var course in Model)
        {
            <div class="col">
                <div class="card course-card h-100 position-relative">
                    @if (course.IsPublished)
                    {
                        <span class="badge bg-success position-absolute top-0 end-0 m-2 shadow-sm">Published</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2 shadow-sm">Draft</span>
                    }

                    @if (!string.IsNullOrEmpty(course.ImageUrl))
                    {
                        <img src="@course.ImageUrl" class="card-img-top" alt="@course.Title" style="height:160px; object-fit:cover;">
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height:160px;">
                            <i class="fa-solid fa-image fa-3x text-muted"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="badge mb-2" style="background: rgba(164,53,240,0.1); color: var(--primary); width: fit-content;">@course.Category?.Name</span>
                        <h5 class="course-title fw-bold" title="@course.Title">@course.Title</h5>
                        <div class="course-price mt-1">$@course.Price</div>

                        <div class="d-flex gap-3 mt-auto pt-3 text-muted small">
                            <span><i class="fa-solid fa-users me-1"></i>@course.Enrollments.Count enrolled</span>
                            <span><i class="fa-solid fa-book-open me-1"></i>@course.Lessons.Count lessons</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3 px-3 d-flex flex-column gap-2">
                        <a asp-action="ManageLessons" asp-route-courseId="@course.Id" class="btn btn-sm btn-primary-custom w-100">
                            <i class="fa-solid fa-layer-group me-1"></i>Curriculum Builder
                        </a>
                        <div class="d-flex justify-content-between gap-2">
                            <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                <i class="fa-solid fa-edit me-1"></i>Edit Details
                            </a>
                            <form asp-action="DeleteCourse" asp-route-id="@course.Id" class="d-inline"
                                  onsubmit="return confirm('Delete this course, all lessons, and related data?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5 my-4">
        <div class="mb-4" style="font-size: 4rem; color: var(--border-color);">
            <i class="fa-solid fa-folder-open"></i>
        </div>
        <h3 class="fw-bold mb-2">You haven't created any courses yet</h3>
        <p class="text-muted mb-4 fs-5">Share your knowledge with thousands of learners worldwide.</p>
        <a asp-action="CreateCourse" class="btn-primary-custom">
            <i class="fa-solid fa-plus me-2"></i>Create Your First Course
        </a>
    </div>
}
